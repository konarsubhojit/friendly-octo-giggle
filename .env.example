# Database (PostgreSQL)
# For local development without SSL: postgresql://user:password@localhost:5432/ecommerce?schema=public&sslmode=disable
# For cloud databases with SSL: postgresql://user:password@host:5432/ecommerce?schema=public
# Note: The app accepts self-signed certificates by default for compatibility with development/cloud databases
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce?schema=public

# Redis Connection (use Upstash Redis for serverless)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# NextAuth Configuration
NEXTAUTH_SECRET=your-nextauth-secret-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Base URL for client-side links (optional)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google OAuth (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth (Personal Accounts Only — register at Azure Portal)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Vercel Blob (for image storage)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-read-write-token

# Exchange Rate API (https://www.exchangerate-api.com/)
# Used for live currency conversion rates. Falls back to hardcoded rates if not set.
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key

# Logging
# debug | info | warn | error
LOG_LEVEL=info

# MailerSend Email (https://www.mailersend.com/)
# Required for order confirmation & status update emails
MAILERSEND_API_KEY=your-mailersend-api-key
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com

# Google SMTP Email (preferred when configured)
# For Gmail, use a Google App Password (requires 2FA enabled)
GOOGLE_SMTP_HOST=smtp.gmail.com
GOOGLE_SMTP_PORT=465
GOOGLE_SMTP_SECURE=true
GOOGLE_SMTP_USER=your-gmail-address@gmail.com
GOOGLE_SMTP_APP_PASSWORD=your-google-app-password
GOOGLE_SMTP_FROM_EMAIL=noreply@yourdomain.com

# Upstash Search (https://console.upstash.com/ → Search)
# Used for full-text search on products and orders
UPSTASH_SEARCH_REST_URL=https://your-upstash-search-url
UPSTASH_SEARCH_REST_TOKEN=your-upstash-search-token
UPSTASH_SEARCH_REST_READONLY_TOKEN=your-upstash-search-readonly-token

# Client-side search (safe to expose — readonly token)
NEXT_PUBLIC_UPSTASH_SEARCH_REST_URL=https://your-upstash-search-url
NEXT_PUBLIC_UPSTASH_SEARCH_REST_READONLY_TOKEN=your-upstash-search-readonly-token

# Playwright E2E Testing (credentials for authenticated test flows)
COPILOT_DEV_EMAIL=your-test-account@example.com
COPILOT_DEV_PASS=your-test-account-password
# Sentry Error Monitoring (https://sentry.io/)
# Optional — Sentry is disabled when not set
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
